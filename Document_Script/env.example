# AstroOracle Knowledge Base Builder — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git

# Supabase — get these from your Supabase project settings > API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# OpenAI — used for generating embeddings (text-embedding-3-small)
# Much cheaper than using Claude for embeddings
# Get from: platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic — used for the actual chat responses in rag-query.js
# Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
