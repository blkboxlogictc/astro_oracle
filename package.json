{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "workspaces": [
    "artifacts/*",
    "lib/*",
    "scripts"
  ],
  "scripts": {
    "dev": "npm run dev:astrooracle",
    "dev:astrooracle": "npm run dev --workspace=artifacts/astrooracle",
    "dev:mockup": "npm run dev --workspace=artifacts/mockup-sandbox",
    "dev:api": "npm run dev --workspace=artifacts/api-server",
    "build": "npm run typecheck && npm run build --workspaces --if-present",
    "typecheck:libs": "tsc --build",
    "typecheck": "npm run typecheck:libs && npm run typecheck --workspaces --if-present"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1",
    "cross-env": "^7.0.3"
  }
}
